# ============================================================================
# ClaimShield AI Backend - Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials.
# ============================================================================

# Application
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Set to true to bypass real Firebase & Supabase setups for local testing
DEMO_MODE=true

# Database (PostgreSQL via Supabase or Local)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/claimshield?schema=public"

# JSON Web Token Secret (used for signing patient/doctor sessions)
JWT_SECRET="claimshield-super-secret-key-change-in-production"

# Supabase Storage Integration (Optional if DEMO_MODE=true)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="medical-records"

# How long the backend waits before failing public/tamper verifications
VERIFY_FETCH_TIMEOUT_MS=20000

# Firebase SDK Auth Setup (Optional if DEMO_MODE=true)
# JSON string of your Firebase service account private key file
FIREBASE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "..."}'
# OR individual key pieces:
# FIREBASE_PROJECT_ID="your-firebase-project-id"
# FIREBASE_CLIENT_EMAIL="your-firebase-client-email"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
